#!/bin/bash
# script: container
# Purpose: open a bash shell inside the container
#          or run a command inside it

# Load environment variables from the .env file
if [ -f .env ]; then
  export $(grep -v -E '^#|^UID=' .env | xargs)
fi

# Define constants
CONTAINER=${PROJECT_NAME}-app

if [ "$#" -eq 0 ]; then
  # No arguments → open interactive shell as devuser
  docker exec -it "$CONTAINER" sudo -u devuser /bin/bash
else
  # Arguments provided → run command as devuser
  docker exec -it "$CONTAINER" sudo -u devuser "$@"
fi